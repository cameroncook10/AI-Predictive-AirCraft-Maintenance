{
  "name": "aeromind-predictive-maintenance",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "cd client && npm run dev",
    "server": "cd server && node index.js",
    "build": "cd client && npm run build",
    "start": "npm run server"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
